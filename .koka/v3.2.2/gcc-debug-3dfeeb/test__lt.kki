fun main // inline size: 3
  = fn<<(std/core/console/console :: X)>>(){
    val b@10001[1,0,1,0] : std/core/types/bool
          = std/core/int/(<)(5, 0);
    std/core/console/printsln((match (b@10001) {
      ((std/core/types/True() : std/core/types/bool ) as @pat: std/core/types/bool)
         -> "True";
      ((@skip std/core/types/False() : std/core/types/bool ) as @pat@0: std/core/types/bool)
         -> "False";
    }));
  };