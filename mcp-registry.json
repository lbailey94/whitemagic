  "installation": {
    "uvx": "uvx whitemagic-mcp",
    "pip": "pip install whitemagic-mcp",
    "pip_full": "pip install whitemagic",
    "source": "git clone https://github.com/lbailey94/whitemagic && cd whitemagic && pip install -e core/.",
    "seed_binary": "curl https://whitemagic.dev/install.sh | sh"
  },
  "configuration": {
    "stdio": {
      "command": "uvx",
      "args": ["whitemagic-mcp"],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "WM_SILENT_INIT": "1",
        "WM_MCP_PRAT": "2"
      }
    },
    "http": {
      "command": "uvx",
      "args": ["whitemagic-mcp", "--http", "--port", "8770"]
    }
  },
  "tool_count": 1,
  "nested_tool_count": 832,
  "requirements": {
    "python": ">=3.12",
    "optional": {
      "rust_bridge": "whitemagic-rs (for polyglot acceleration)",
      "ollama": "Ollama server (for local LLM inference)",
      "redis": "Redis server (for broker/messaging)"
    }
  }
