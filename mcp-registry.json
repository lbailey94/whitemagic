  "categories": ["memory", "governance", "intelligence", "infrastructure"],
  "tags": [
    "memory", "persistent-memory", "holographic-index", "knowledge-graph",
    "governance", "ethics", "dharma", "karma",
    "self-awareness", "introspection", "metacognition",
    "dream-cycle", "association-mining", "pattern-detection",
