# OpenRouter (for Librarian)
OPENROUTER_API_KEY=<PASTE_KEY_HERE>
LIBRARIAN_MONTHLY_CAP_USD=25

# Upstash Redis (for Rate Limiting / Karma Ledger)
UPSTASH_REDIS_REST_URL=<PASTE_URL_HERE>
UPSTASH_REDIS_REST_TOKEN=<PASTE_TOKEN_HERE>

# Stripe (Optional - leave empty if not verified yet)
NEXT_PUBLIC_STRIPE_OFFICE_HOURS_URL=
NEXT_PUBLIC_STRIPE_ARCHITECTURE_REVIEW_URL=

# Admin (for /admin access)
ADMIN_PASSWORD_HASH=placeholder_change_me

# Resend (contact form + Librarian submit_contact_request notifications)
# Leave blank to disable email notifications (submissions still land in /admin feed).
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=
# Optional sender; defaults to Resend onboarding address until domain is verified.
CONTACT_FROM_EMAIL=
